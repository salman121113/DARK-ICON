rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /group_messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.text.size() < 1000;
    }
    match /ai_chats/{chatId} {
      allow read, write: if true; // In a real app, would restrict by userId
    }
  }
}
